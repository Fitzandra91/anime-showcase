:root {
    --primary-color: #3498db;
    --secondary-color: #2ecc71;
    --background-color: #ecf0f1;
    --text-color: #333;

    /* color theme */

    .light { 
        background-color: var(--background-color);
        color: var(--text-color);
    }

    .dark {
        background-color: #2c3e50;
        color: var(--text-color);}

    }


.body {  background-color: red; }

